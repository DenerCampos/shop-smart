# Ambiente
NODE_ENV=development
FRONTEND_URL=https://superfamilyquest.netlify.app

# API
API_HOST=0.0.0.0
API_PORT=3000
# Proxies na frente da API (Nginx/Ingress): número de hops para Express trust proxy (0 = desligado)
API_TRUST_PROXY_HOPS=0
# Winston: error|warn|info|http|verbose|debug|silly. Produção padrão=warn (sem info no Loki). Para enviar http_request: info
API_LOG_LEVEL=

BCRYPT_SALT=10
JWT_SECRET_KEY=

# Redis
API_REDIS_HOST=redis
API_REDIS_PORT=6379

# AWS (opcional)
API_AWS_ACCESS_KEY_ID=
API_AWS_SECRET_ACCESS_KEY=
API_AWS_REGION=

# SSL
SSL_CERT=/etc/ssl/certs/ca-certificates.crt

# MySQL
API_DB_HOST=db
API_DB_PORT=3306
API_DB_USER=shop_smart
API_DB_PASS=shop_smart
API_DB_NAME=shop_smart
API_DB_ROOT_PASS=root

# Container Docker do MySQL (opcional): usado por npm run db:create quando não há cliente mysql no host
MYSQL_DOCKER_CONTAINER=

# Backup Oracle
ORACLE_INSTANCE_IP=000.000.000.000
ORACLE_SSH_KEY_PATH=~/.ssh/ssh-key-oracle-super-family-quest.key
ORACLE_BACKUP_PATH=/opt/shop_smart/backups
LOCAL_BACKUP_PATH=/home/dener/projetos/shop_smart/api/db/backup

#Image Recognition
DEFAULT_RECOGNITION_PROVIDER=gemini
GOOGLE_API_KEY=

# Gemini API - Controle de Quota
# Limite diário de requisições para o Gemini (padrão: 50)
# Ajuste conforme seu plano: Flash (1500/dia) ou Pro (50/dia)
GEMINI_DAILY_LIMIT=50
GEMINI_AUDIO_DAILY_LIMIT=50
GEMINI_TEXT_DAILY_LIMIT=50

# Google Drive (Profile Image)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_RATE_LIMIT=50

# Grafana Cloud Loki (Explore → datasource Loki; query ex.: {app="shop-smart-api"})
# LOKI_HOST = só a URL base (sem /loki/api/v1/push)
LOKI_ENABLED=false
LOKI_HOST=https://logs-prod-us-central1.grafana.net
LOKI_USER_ID=123456
LOKI_API_TOKEN=
