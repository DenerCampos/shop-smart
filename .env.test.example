# Copie para .env.test na raiz do projeto (não commitar).
# Banco E2E: shop_smart_test (ver scripts/create-shop-smart-databases.sh).

NODE_ENV=test
FRONTEND_URL=http://localhost:5173

API_HOST=0.0.0.0
API_PORT=3000

BCRYPT_SALT=10
JWT_SECRET_KEY=e2e-test-only-jwt-secret-min-32-chars-ok

API_REDIS_HOST=127.0.0.1
API_REDIS_PORT=6379

API_AWS_ACCESS_KEY_ID=
API_AWS_SECRET_ACCESS_KEY=
API_AWS_REGION=

SSL_CERT=

API_DB_HOST=127.0.0.1
API_DB_PORT=3306
API_DB_USER=shop_smart
API_DB_PASS=shop_smart
API_DB_NAME=shop_smart_test
API_DB_ROOT_PASS=root

# Sem cliente mysql no host, npm run db:create usa docker exec neste container (ex.: gym-flow-mysql)
MYSQL_DOCKER_CONTAINER=

# Opcional: usuário MySQL só para o banco de teste (senão use o mesmo API_DB_USER nos dois bancos).
# API_DB_USER_TEST=shop_smart_test
# API_DB_PASS_TEST=shop_smart_test

ORACLE_INSTANCE_IP=000.000.000.000
ORACLE_SSH_KEY_PATH=~/.ssh/ssh-key-oracle-super-family-quest.key
ORACLE_BACKUP_PATH=/opt/shop_smart/backups
LOCAL_BACKUP_PATH=/home/dener/projetos/shop_smart/api/db/backup

DEFAULT_RECOGNITION_PROVIDER=gemini
GOOGLE_API_KEY=

GEMINI_DAILY_LIMIT=50
GEMINI_AUDIO_DAILY_LIMIT=50
GEMINI_TEXT_DAILY_LIMIT=50

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_RATE_LIMIT=50

LOKI_ENABLED=false
LOKI_HOST=https://logs-prod-us-central1.grafana.net
LOKI_USER_ID=
LOKI_API_TOKEN=
