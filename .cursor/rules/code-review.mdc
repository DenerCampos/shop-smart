#### Nomes Descritivos
```typescript
// CORRETO: Nomes claros
const calculateTotalExpensesForMonth = (expenses: Expense[]) => {
  return expenses.reduce((sum, expense) => sum + expense.value, 0);
};

// ERRADO: Nomes vagos
const calc = (arr: any[]) => { // ❌ Nome não descritivo
